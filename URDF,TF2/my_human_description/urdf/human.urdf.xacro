<?xml version="1.0"?>
<robot name="simple_human" xmlns:xacro="http://ros.org/wiki/xacro">
<!--torso-->
    <link name="torso">
        <visual>
            <geometry>
                <box size="0.3 0.2 0.5"/>
            </geometry>
            <material name="blue">
                <color rgba="0.0 0.0 1.0 1.0"/>
            </material>
        </visual>
    </link>
<!--head-->
    <link name="head">
        <visual>
            <geometry>
                <sphere radius="0.15"/>
            </geometry>
            <material name="green">
                <color rgba="0.0 1.0 0.0 1.0"/>
            </material>           
        </visual>
    </link>
<!--neck-->
    <joint name="neck" type="fixed">
        <parent link="torso"/>
        <child link="head"/>
        <origin xyz="0 0 0.35"/>
    </joint>

<xacro:macro name="arm" params="name y_pos">
<!--arm-->
    <link name="${name}_arm">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.4"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
        </visual>   
    </link>

    <joint name="${name}_shoulder" type="revolute">
        <parent link="torso"/>
        <child link="${name}_arm"/>
        <origin xyz="0 ${y_pos} 0.0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.7" upper="0.7" effort="10" velocity="1"/>
    </joint>
</xacro:macro>

    <!-- leg-->
<xacro:macro name="leg" params="name y_pos">
    <link name="${name}_leg">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.5"/>
            </geometry>
            <material name="yellow">
                <color rgba="1.0 1.0 0.0 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="${name}_hip" type="revolute">
        <parent link="torso"/>
        <child link="${name}_leg"/>
        <origin xyz="0 ${y_pos} -0.3"/>
        <axis xyz="0 1.0 0.0"/>
        <limit lower="-0.7" upper="0.7" effort="10" velocity="1"/>
    </joint>
</xacro:macro>

<xacro:arm name="left" y_pos="0.15"/>
<xacro:arm name="right" y_pos="-0.15"/>
<xacro:leg name="left" y_pos="0.1"/>
<xacro:leg name="right" y_pos="-0.1"/>



</robot>